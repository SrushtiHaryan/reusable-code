name: {{ name | default("my-app") }}

replicaCount: {{ replicaCount | default(1) }}

image:
  repository: {{ image.repository | default("nginx") }}
  tag: {{ image.tag | default("latest") }}
  pullPolicy: {{ image.pullPolicy | default("IfNotPresent") }}
  environment: {{ image.environment | default("dev") }}

service:
  type: {{ service.type | default("ClusterIP") }}
  port: {{ service.port | default(80) }}
  targetPort: {{ service.targetPort | default(80) }}

resources:
{{ to_yaml(resources | default({})) | indent(2, true) }}

labels:
{{ to_yaml(labels | default({})) | indent(2, true) }}

env:
{{ to_yaml(env | default([])) | indent(2, true) }}

envFrom:
{{ to_yaml(envFrom | default([])) | indent(2, true) }}

secrets:
{{ to_yaml(secrets | default([])) | indent(2, true) }}

configmaps:
{{ to_yaml(configmaps | default([])) | indent(2, true) }}

volumes:
{{ to_yaml(volumes | default([])) | indent(2, true) }}

volumeMounts:
{{ to_yaml(volumeMounts | default([])) | indent(2, true) }}

ingress:
{{ to_yaml(ingress | default({})) | indent(2, true) }}

nodeSelector:
{{ to_yaml(nodeSelector | default({})) | indent(2, true) }}

affinity:
{{ to_yaml(affinity | default({})) | indent(2, true) }}

tolerations:
{{ to_yaml(tolerations | default([])) | indent(2, true) }}
