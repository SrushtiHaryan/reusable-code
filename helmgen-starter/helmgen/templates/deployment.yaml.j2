{% raw %}apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Values.name }}
  namespace: {{ .Release.Namespace}}
  labels:
    app.kubernetes.io/name: {{ .Values.name }}
    app.kubernetes.io/instance: {{ .Release.name }}
    app.kubernetes.io/version:
    app.kubernetes.io/managed-by: 

    {{- if .Values.labels }}
{{ toYaml .Values.labels | nindent 4 }}
    {{- end }}
spec:
  replicas: {{ .Values.replicaCount }}
  selector:
    matchLabels:
      type: {{ .Values.app.name }}
      service: {{ .Values.app.name }}
  template:
    metadata:
      labels:
        type: {{ .Values.app.name }}
        service: {{ .Values.app.name }}
{{ toYaml .Values.labels | nindent 8 }}
        {{- end }}
    spec:
      containers:
        - name: {{ .Values.name }}
          image: {{ .Values.image }}
          imagePullPolicy: {{ .Values.imagePullPolicy }}
          ports:
            - containerPort: {{ .Values.service.port }}
          resources:
{{ toYaml .Values.resources | nindent 12 }}
          env:
          - name:
            value:
          - name: SFTPKEYSTORE
            value: {{ Values.secrets.sftpKeyStoreLocation }}
          - name:
            valueFrom: 
              secretKeyRef:
                key: spring_datasource_password
                name: {{ Values.secrets.dbPassword }}
          - name:
            valueFrom: 
              secretKeyRef:
                key:
                name: 
          - name:
            valueFrom: 
              secretKeyRef:
                key:
                name: 
          envFrom:
           - configMapRef
              name: '{{ .Values.configmaps.envmap }}-{{.Values.image.environment}}'
          volumeMounts:
           - mountPath: /deployments/resources/pli-api/props/keystore
             name: keystore-details
          volumes:
           - name: keystore-details
             secret:
              secretName: '{{ .Values.secrets.keyStore }}-{{.Values.image.environment}}'
           - configMap:
             defaultMode:
             name: '{{ .Values.configmaps.envmap }}-{{.Values.image.environment}}'
          nodeSelectore:
          affinity:
          tolerations:

{% endraw %}
